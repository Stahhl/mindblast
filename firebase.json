{
  "functions": [
    {
      "source": "src/apps/feedback-api",
      "codebase": "feedback-api",
      "predeploy": [
        "pnpm --dir \"$RESOURCE_DIR\" install --no-frozen-lockfile",
        "pnpm --dir \"$RESOURCE_DIR\" build"
      ],
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "hosting": [
    {
      "target": "staging",
      "public": ".firebase/staging",
      "ignore": [
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "/quizzes/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-store"
            }
          ]
        },
        {
          "source": "/assets/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "/api/**",
          "function": "quizFeedbackApi"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "production",
      "public": ".firebase/production",
      "ignore": [
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "/quizzes/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-store"
            }
          ]
        },
        {
          "source": "/assets/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "/api/**",
          "function": "quizFeedbackApi"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
