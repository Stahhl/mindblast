{
  "hosting": [
    {
      "target": "staging",
      "public": ".firebase/staging",
      "ignore": [
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "/quizzes/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-store"
            }
          ]
        },
        {
          "source": "/assets/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "production",
      "public": ".firebase/production",
      "ignore": [
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "/quizzes/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-store"
            }
          ]
        },
        {
          "source": "/assets/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
