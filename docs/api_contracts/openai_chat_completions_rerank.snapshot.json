  "source_urls": [
    "https://platform.openai.com/docs/api-reference/chat/create-chat-completion",
    "https://platform.openai.com/docs/api-reference/chat/create#chat-createtemperature",
    "https://platform.openai.com/docs/guides/reasoning"
  ],
  "request_profiles": {
    "reasoning_models": {
      "description": "Models that support reasoning_effort parameter (e.g. gpt-5-mini, o1, o3).",
      "model_prefixes": [
        "gpt-5-mini",
        "o1",
        "o3"
      ],
      "required_params": [
        "model",
        "messages",
        "response_format",
        "max_completion_tokens",
        "reasoning_effort"
      ],
      "forbidden_params": [
        "max_tokens",
        "temperature"
      ],
      "fixed_values": {
        "response_format.type": "json_object",
        "reasoning_effort": "minimal"
      }
    },
    "gpt5_standard_chat_models": {
      "description": "Standard GPT-5 chat models (e.g. gpt-5.2) that require max_completion_tokens but do NOT support reasoning_effort.",
      "model_prefix": "gpt-5",
      "excludes": [
        "gpt-5-mini"
      ],
      "required_params": [
        "model",
        "messages",
        "response_format",
        "max_completion_tokens",
        "temperature"
      ],
      "forbidden_params": [
        "max_tokens",
        "reasoning_effort"
      ],
      "fixed_values": {
        "response_format.type": "json_object",
        "temperature": 0
      }
    },
    "legacy_chat_models": {
      "description": "Non-GPT-5 models (e.g. gpt-4o, gpt-4o-mini).",
      "required_params": [
        "model",
        "messages",
        "response_format",
        "max_tokens",
        "temperature"
      ],
      "forbidden_params": [
        "max_completion_tokens",
        "reasoning_effort"
      ],
      "fixed_values": {
        "response_format.type": "json_object",
        "temperature": 0
      }
    }
  },
  "response_contract": {
    "primary_ranked_ids_key": "ranked_distractor_ids",
    "accepted_ranked_ids_keys": [
      "ranked_distractor_ids",
      "selected_distractor_ids",
      "selected",
      "distractors",
      "ranked_ids"
    ]
  }
}
