rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Feedback writes are backend-only in Phase 6.
    match /quiz_feedback/{document=**} {
      allow read, write: if false;
    }

    match /quiz_feedback_rate_limits/{document=**} {
      allow read, write: if false;
    }

    // Signed-in progress and draft feedback are backend-only. Clients must use
    // the authenticated API so Auth, App Check, validation, and rate limits apply.
    match /user_quiz_state/{document=**} {
      allow read, write: if false;
    }

    match /user_feedback_drafts/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
